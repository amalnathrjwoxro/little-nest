option_settings:
  aws:elasticbeanstalk:cloudwatch:logs:
    StreamLogs: true
    DeleteOnTerminate: false
    RetentionInDays: 7
  aws:elasticbeanstalk:application:environment:
    NODE_ENV: production
    PORT: 3000
    HOSTNAME: 0.0.0.0

files:
  "/opt/elasticbeanstalk/tasks/bundlelogs.d/docker.conf":
    mode: "000755"
    owner: root
    group: root
    content: |
      /var/log/docker
      /var/log/eb-docker.log