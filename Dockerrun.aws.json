{
  "AWSEBDockerrunVersion": 2,
  "containerDefinitions": [
    {
      "name": "app-payload",
      "image": "app-payload:latest",
      "memory": 512,
      "essential": true,
      "portMappings": [
        {
          "hostPort": 80,
          "containerPort": 3000
        }
      ],
      "environment": [
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "HOSTNAME",
          "value": "0.0.0.0"
        },
        {
          "name": "PORT",
          "value": "3000"
        }
      ]
    }
  ]
}